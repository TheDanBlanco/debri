{
  "name": "debri",
  "version": "0.1.0-alpha.0",
  "description": "Type-safe DynamoDB single-table library with multi-key GSI support",
  "license": "MIT",
  "author": "Daniel Blanco",
  "repository": {
    "type": "git",
    "url": "https://github.com/TheDanBlanco/debri.git"
  },
  "homepage": "https://github.com/TheDanBlanco/debri#readme",
  "bugs": {
    "url": "https://github.com/TheDanBlanco/debri/issues"
  },
  "keywords": [
    "dynamodb",
    "single-table",
    "typescript",
    "zod",
    "aws-sdk"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "examples:typecheck": "tsc -p tsconfig.examples.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check ./src",
    "lint:fix": "biome check --write ./src",
    "coverage": "vitest run --coverage"
  },
  "peerDependencies": {
    "@aws-sdk/client-dynamodb": "^3.0.0",
    "@aws-sdk/lib-dynamodb": "^3.0.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@aws-sdk/client-dynamodb": "^3.1018.0",
    "@aws-sdk/lib-dynamodb": "^3.1018.0",
    "@biomejs/biome": "2.4.9",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2",
    "zod": "^4.3.6"
  }
}
